# ============================================
# Renova Parse App — Environment Variables
# ============================================
# Скопируйте в .env и заполните своими значениями

# --- База данных (PostgreSQL через Docker) ---
DATABASE_URL=postgresql://renova:password@localhost:5433/renova

# --- Redis (очереди Celery) ---
REDIS_URL=redis://localhost:6379/0

# --- Proxy: Decodo Residential (Playwright / MyBuildingPermit) ---
# Документация: docs/integrations/decodo/README.md
# Формат: http://USERNAME:PASSWORD@HOST:PORT (для *.decodo.com лучше http://, не https:// — иначе мы всё равно нормализуем в коде)
# US sticky: часто us.decodo.com:10001+ (см. дашборд Proxy setup). Rotating: gate.decodo.com:7000 или us.decodo.com:10000
PROXY_URL=http://username:password@us.decodo.com:10001

# Опционально: API статистики Decodo (traffic/targets) — см. docs/integrations/decodo/README.md
# DECODO_API_KEY=

# --- Telegram Bot (алерты + ручной апрув лидов) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_manager_chat_id_here

# --- Outbound: Lob (физические письма) ---
# Используйте TEST ключ для проверки!
LOB_API_KEY=test_your_lob_test_key_here
LOB_DAILY_LIMIT=5

# --- Outbound: BatchData (Skip Tracing & Property Search) ---
BATCHDATA_API_KEY=

# --- Outbound: SendGrid (Email) ---
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=hello@renova.contractors
SENDGRID_FROM_NAME=Renova Contractors

# --- Outbound: Twilio (SMS) ---
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_PHONE_NUMBER=+12065551234

# --- Тесты отправки (test/test_outbound) ---
# TEST_EMAIL=your@email.com
# TEST_PHONE=+12065559999
# TEST_EMAIL_NAME=Michael   # подставляется вместо [name] в long-письмах (run_send_long_emails.py)

# --- BatchData: только Skip Trace (контакты, email). HELOC/Property Search отложен ---
# BATCHDATA_API_KEY=  (уже в Outbound секции выше)
