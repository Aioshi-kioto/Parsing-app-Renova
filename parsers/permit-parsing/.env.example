# Seattle Permits API
SOCRATA_APP_TOKEN=your_app_token_here
SOCRATA_DOMAIN=data.seattle.gov
SOCRATA_DATASET_ID=76t5-zqzr

# Database (optional)
DATABASE_URL=postgresql://user:password@localhost:5432/permits_db

# Proxy Settings (optional)
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# Scraping Settings
MAX_CONCURRENT_BROWSERS=3
REQUEST_DELAY_MS=2000
HEADLESS=true
