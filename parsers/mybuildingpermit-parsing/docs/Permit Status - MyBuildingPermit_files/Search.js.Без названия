function search(criteria) {
    switch (criteria) {
        case "permitnumber":
            $("#radioPermitNum").attr("checked", "checked");
            clearProjectInfoSearch();
            clearPeopleSearch();
            clearLocationSearch();           
            clearDateRangeSearch();
            $("#divPermitSearch").show();
            $("#divProjectInfoSearch").hide();
            $("#divLocationSearch").hide();
            $("#divPeopleSearch").hide();
            break;

        case "projectinfo":
            $("#radioProjectInfo").attr("checked", "checked");
            clearPermitSearch();
            clearPeopleSearch();
            clearLocationSearch();
            clearDateRangeSearch();
            $("#divPermitSearch").hide();
            $("#divProjectInfoSearch").show();
            $("#divLocationSearch").hide();
            $("#divPeopleSearch").hide();
            break;

        case "location":
            $("#radioLocation").attr("checked", "checked");
            clearProjectInfoSearch();
            clearPeopleSearch();
            clearPermitSearch();
            clearDateRangeSearch();
            $("#divPermitSearch").hide();
            $("#divProjectInfoSearch").hide();
            $("#divLocationSearch").show();
            $("#divPeopleSearch").hide();
            break;

        case "people":
            $("#radioPeople").attr("checked", "checked");
            clearProjectInfoSearch();
            clearPermitSearch();
            clearLocationSearch();            
            clearDateRangeSearch();

            $("#divPermitSearch").hide();
            $("#divProjectInfoSearch").hide();
            $("#divLocationSearch").hide();
            $("#divPeopleSearch").show();
            break;

        default:
            $("#divPermitSearch").show();
            $("#divProjectInfoSearch").hide();
            $("#divLocationSearch").hide();
            $("#divPeopleSearch").hide();
            break;
    }
}

