function submitSearch() {
    if ($("#permitSearchForm").valid()) {
        var formData = $("#permitSearchForm").serialize();

        $('#divWaitMessage').removeClass('hidden');
        $('#searchError').addClass('hidden');
        $('#gridcontainer').addClass('hidden');


        $.ajax({
            type: "POST",
            dataType: "json",
            url: "/SearchPermits/GetSearchResults",
            data: formData
        })
            .done(function (datasource) {
                bindResultsGrid(datasource);
                $('#gridContainer').removeClass('hidden');
                $('#divWaitMessage').addClass('hidden');
            })
            .fail(function () {
                $('#searchError').removeClass('hidden');;
                $('#divWaitMessage').addClass('hidden');
            });
    }
}

function bindResultsGrid(datasource) {
    var ds = new kendo.data.DataSource({
        data: datasource,
        schema:
        {
            model: {
                fields: {
                    AppliedDate: { type: "date" },
                    IssuedDate: { type: "date" },
                    FinaledDate: { type: "date" },
                    ApplicationExpDate: { type: "date" }
                }
            }
        }
    });
    var grid = $("#searchResultsGrid").data("kendoGrid");
    grid.setDataSource(ds);
}

function validateDates() {

    // var thisControl = $('#' + this.id).data("kendoDatePicker");
    if (this.value() == null) {
        alert("Please enter valid date.");
        this.value('');
        $('#' + this.id).focus();
    } else {

        var startDate = $("#FromDate").data("kendoDatePicker");
        var endDate = $("#ToDate").data("kendoDatePicker");

        if ((startDate.value() !== null && endDate.value() !== null) &&
            endDate.value() < startDate.value()) {
            alert("\"To\" date cannot be before the \"From\" date.");
            this.value('');
        } else if ((startDate.value() !== null && endDate.value() !== null) &&
            startDate.value() > endDate.value()) {
            alert("\"From\" date cannot be after the \"To\" date.");
            this.value('');
        } else {
            kendo.toString(startDate, "MM/dd/yyyy");
            kendo.toString(endDate, "MM/dd/yyyy");
        }
    }
}

function toggleDateControls() {
    var startDate = $("#FromDate").data("kendoDatePicker");
    var endDate = $("#ToDate").data("kendoDatePicker");
    if (this.dataItems().length === 0) {
        startDate.value(''), endDate.value('');
        startDate.readonly();
        endDate.readonly();
    } else {
        startDate.readonly(false);
        endDate.readonly(false);
    }
}

function getJurisdictionMessage() {
    var id = $('#ddlJurisdictions').val();
    $.ajax({
            type: "GET",
            contentType: "application/json; charset=utf-8",
            datatype: "json",
            url: "/SearchPermits/GetJurisMessage",
            data: 'jurisId=' + id
        })
        .success(function (data) {
            if (data !== '' && data.success !== typeof (undefined) && data.success === false) {
                $('#divJurisMessage').html('');
                $('#divJurisMessage').addClass('hidden');
            } else {
                if (data.message && data.message !== "") {
                    $('#divJurisMessage').html(data.message);
                    $('#divJurisMessage').removeClass('hidden');
                } else {
                    $('#divJurisMessage').html('');
                    $('#divJurisMessage').addClass('hidden');
                }

            }
        })
        .error(function (error) {
            $('#divJurisMessage').html('');
            $('#divJurisMessage').addClass('hidden');
        });

}

function isValidDate(d) {
    if (!(d instanceof Date)) {
        var date_regex = /^(0?[1-9]|1[0-2])\/(0?[1-9]|1\d|2\d|3[01])\/(19|20)?\d{2}$/;
        var dt = new Date(d);
        return date_regex.test(d) && dt instanceof Date && dt != "Invalid Date" && !isNaN(dt);
    }
    return true;
}
